load("//tools/bazel:archiva.bzl", "archiva_module")

archiva_module(
    name = "metadata-repository-api",
    # The only test file is an abstract base (AbstractMetadataRepositoryTest)
    # that needs //archiva-modules/plugins/generic-metadata-support to compile,
    # which in turn depends back on this module. Concrete subclasses live in
    # downstream provider modules — skip test compilation here.
    skip_tests = True,
    deps = [
        "//archiva-modules/archiva-base/archiva-common",
        "//archiva-modules/archiva-base/archiva-policies",
        "//archiva-modules/archiva-base/archiva-repository-api",
        "//archiva-modules/archiva-base/archiva-storage-api",
        "//archiva-modules/archiva-base/archiva-xml-tools",
        "//archiva-modules/metadata/metadata-model",
        "//third_party/archiva-components/spring-cache-api",
        "@maven//:jakarta_annotation_jakarta_annotation_api",
        "@maven//:javax_inject_javax_inject",
        "@maven//:org_apache_commons_commons_collections4",
        "@maven//:org_apache_commons_commons_lang3",
        "@maven//:org_slf4j_slf4j_api",
        "@maven//:org_springframework_spring_beans",
        "@maven//:org_springframework_spring_context",
    ],
)
